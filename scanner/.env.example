# Supabase project credentials (Project Settings > API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY
# Your Supabase auth user id (Authentication > Users, after you sign up in the web app)
SUPABASE_USER_ID=YOUR_USER_ID

# Telegram bot (create via @BotFather, see DEPLOY.md)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# How often the scanner re-checks the market, in minutes
SCAN_INTERVAL_MINUTES=15
